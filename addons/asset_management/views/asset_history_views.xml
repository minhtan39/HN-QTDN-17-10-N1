<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================= TREE VIEW ================= -->
    <record id="view_asset_history_tree" model="ir.ui.view">
        <field name="name">asset.history.tree</field>
        <field name="model">asset.history</field>
        <field name="arch" type="xml">
            <tree>
                <field name="category_id"/>
                <field name="employee_id"/>
                <field name="location_id"/>
                <field name="quantity"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="status"/>
                <field name="total_damage_cost" sum="Tổng chi phí thiệt hại"/>
            </tree>
        </field>
    </record>

    <!-- ================= FORM VIEW ================= -->
    <record id="view_asset_history_form" model="ir.ui.view">
        <field name="name">asset.history.form</field>
        <field name="model">asset.history</field>
        <field name="arch" type="xml">
            <form>

                <header>
                    <button name="action_return"
                            type="object"
                            string="Trả tài sản"
                            class="btn-primary"
                            attrs="{'invisible': [('status', '=', 'returned')]}"/>
                </header>

                <sheet>
                    <group>
                        <field name="category_id"
                               attrs="{'readonly': [('status', '=', 'returned')]}"/>

                        <field name="employee_id"
                               attrs="{'readonly': [('status', '=', 'returned')]}"/>

                        <field name="location_id"
                               attrs="{'readonly': [('status', '=', 'returned')]}"/>

                        <field name="quantity"
                               attrs="{'readonly': [('status', '=', 'returned')]}"/>

                        <field name="start_date"
                               attrs="{'readonly': [('status', '=', 'returned')]}"/>

                        <field name="end_date" readonly="1"/>
                        <field name="status" readonly="1"/>
                    </group>

                    <group string="Thiệt hại khi trả">
                        <field name="damage_type"
                               attrs="{'readonly': [('status', '=', 'returned')]}"/>

                        <field name="damage_cost"
                               attrs="{
                                   'invisible': [('damage_type', '=', 'none')],
                                   'readonly': [('status', '=', 'returned')]
                               }"/>

                        <field name="damage_note"
                               attrs="{
                                   'invisible': [('damage_type', '=', 'none')],
                                   'readonly': [('status', '=', 'returned')]
                               }"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================= PIVOT VIEW ================= -->
    <record id="view_asset_history_pivot" model="ir.ui.view">
        <field name="name">asset.history.pivot</field>
        <field name="model">asset.history</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="employee_id" type="row"/>
                <field name="category_id" type="row"/>
                <field name="location_id" type="row"/>
                <field name="quantity" type="measure"/>
                <field name="total_damage_cost" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ================= SEARCH VIEW ================= -->
    <record id="view_asset_history_search" model="ir.ui.view">
        <field name="name">asset.history.search</field>
        <field name="model">asset.history</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="category_id"/>
                <field name="location_id"/>

                <filter name="filter_using"
                        string="Đang mượn"
                        domain="[('status','=','using')]"/>

                <filter name="filter_returned"
                        string="Đã trả"
                        domain="[('status','=','returned')]"/>

                <filter name="filter_damage"
                        string="Có thiệt hại"
                        domain="[('damage_type','!=','none')]"/>
            </search>
        </field>
    </record>

</odoo>
