<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="cham_cong_tree" model="ir.ui.view">
        <field name="name">cham.cong.tree</field>
        <field name="model">cham_cong</field>
        <field name="arch" type="xml">
            <tree>
                <field name="ma_cham_cong"/>
                <field name="nhan_vien_id"/>
                <field name="ngay"/>
                <field name="gio_vao"/>
                <field name="gio_ra"/>
                <field name="tong_so_gio_lam"/>
                <field name="gio_ot"/>
                <field name="trang_thai"/>
            </tree>
        </field>
    </record>

    <record id="cham_cong_form" model="ir.ui.view">
        <field name="name">cham.cong.form</field>
        <field name="model">cham_cong</field>
        <field name="arch" type="xml">
            <form string="Chấm công">
                <sheet>
                    <group>
                        <field name="ma_cham_cong"/>
                        <field name="nhan_vien_id"/>
                        <field name="ngay"/>
                        <field name="trang_thai"/>
                    </group>

                    <group>
                        <field name="gio_vao"/>
                        <field name="gio_ra"/>
                        <field name="tong_so_gio_lam" readonly="1"/>
                        <field name="gio_ot" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
